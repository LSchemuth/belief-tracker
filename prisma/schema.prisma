generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BeliefMap {
  id         String   @id @default(cuid())
  name       String
  xAxisLabel String
  xAxisLow   String
  xAxisHigh  String
  yAxisLabel String
  yAxisLow   String
  yAxisHigh  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  entries    Entry[]
}

model Entry {
  id        String    @id @default(cuid())
  title     String
  content   String
  type      String
  url       String?
  summary   String?
  notes     String?
  agreement Float     @default(0)
  weight    Float     @default(0.5)
  xSignal   Float     @default(0)
  ySignal   Float     @default(0)
  topics    String    @default("")
  mapId     String
  map       BeliefMap @relation(fields: [mapId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
